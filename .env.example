# ============================================================
# ARGOS QG — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# --- OBRIGATÓRIAS (S-1, S-2, S-3) ----------------------------

# Chave secreta do Flask para assinar sessões e cookies.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROCAR-POR-VALOR-SEGURO

# Chave de API usada pelo Pi para autenticar no QG.
# Deve ser idêntica à configurada em RASPBERRY/config/settings.py (QG_API_KEY).
QG_API_KEY=argos-secret-2026

# Senha do usuário admin (criada apenas na primeira execução — seed).
# Se não definida, uma senha aleatória é gerada e exibida nos logs de boot.
ADMIN_PASSWORD=TROCAR-POR-SENHA-SEGURA

# Senha do usuário operador (criada apenas na primeira execução — seed).
# Opcional — se não definida, usa "operador2026".
# OPERADOR_PASSWORD=operador2026

# --- BANCO DE DADOS -------------------------------------------

# URL de conexão com o banco. Em produção (Railway), a env var DATABASE_URL
# é preenchida automaticamente pelo plugin PostgreSQL.
DATABASE_URL=sqlite:///argos_qg.db

# --- SERVIDOR -------------------------------------------------

PORT=5000
